    "assert:forge-ui-placement": "node scripts/assertForgeUiPlacementParity.mjs",
    "assert:architecture": "node scripts/assertArchitectureBoundaries.mjs",
    "assert:module-boundary-decomposition": "node scripts/assertModuleBoundaryDecomposition.mjs",
    "assert:reducer-purity-strictmode": "node scripts/assertReducerPurityStrictMode.mjs",
    "assert:game-loop": "node scripts/assertGameLoopHeartbeatParity.mjs",
    "assert:visual-fps-cap": "node scripts/assertVisualFpsCapParity.mjs",
    "assert:pet-window-selection": "node scripts/assertPetWindowSelectionParity.mjs",
    "assert:pet-window": "node scripts/assertPetWindowParity.mjs",
    "assert:scroll-panel": "node scripts/assertScrollPanelParity.mjs",
    "assert:text-resources": "node scripts/assertTextResourceEncoding.mjs",
    "assert:source-encoding": "node scripts/assertSourceTextEncoding.mjs",
    "assert:common-cell": "node scripts/assertCommonCellParity.mjs",
    "assert:effects": "node scripts/assertEffectParity.mjs",
    "assert:asset-modules": "node scripts/assertAssetModuleParity.mjs",
    "assert:responsive-layout": "node scripts/assertResponsiveMainLayoutParity.mjs",
    "smoke:responsive-layout": "node scripts/smokeResponsiveLayout.mjs",
    "preview": "vite preview --config vite.config.mjs --configLoader native"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "~5.6.2",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.local.bwe",
    "productName": "BWE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
