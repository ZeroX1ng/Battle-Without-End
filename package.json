{
  "name": "boe-refactor",
  "private": true,
  "version": "0.2.1",
  "description": "BWE desktop playtest build",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --config vite.config.mjs --configLoader native",
    "build": "tsc -b && vite build --config vite.config.mjs --configLoader native",
    "test": "npm run assert:gate:changed",
    "pack:exe": "npm run build && electron-builder --win portable --x64",
    "assert:gate:baseline": "node scripts/runGuardGate.mjs baseline",
    "assert:gate:changed": "node scripts/runGuardGate.mjs changed",
    "assert:gate:all": "node scripts/runGuardGate.mjs all",
    "assert:gate:ci": "node scripts/runGuardGate.mjs ci",
    "assert:preflight": "node scripts/assertPreflight.mjs",
    "assert:repo-hygiene": "node scripts/assertRepoHygiene.mjs",
    "assert:other-panel": "node scripts/assertOtherPanelParity.mjs",
    "assert:other-window-children": "node scripts/assertOtherWindowChildrenParity.mjs",
    "assert:other-window-overlay": "node scripts/assertOtherWindowOverlayParity.mjs",
    "assert:system-window": "node scripts/assertSystemWindowParity.mjs",
    "assert:item-window": "node scripts/assertItemWindowParity.mjs",
