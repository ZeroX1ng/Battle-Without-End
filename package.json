    "assert:drop-filter-auto-sell": "node scripts/assertDropFilterAutoSellParity.mjs",
    "assert:age-growth-visible": "node scripts/assertAgeGrowthVisibleParity.mjs",
    "assert:battle-log-sticky-scroll": "node scripts/assertBattleLogStickyScrollParity.mjs",
    "assert:test-speed-control": "node scripts/assertTestSpeedControlParity.mjs",
    "assert:shop-window": "node scripts/assertShopWindowParity.mjs",
    "assert:battle-player-state": "node scripts/assertBattlePlayerStateParity.mjs",
