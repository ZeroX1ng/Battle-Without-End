    "assert:battle-damage-flat-output": "node scripts/assertBattleDamageFlatOutputParity.mjs",
    "assert:battle-death-penalty": "node scripts/assertBattleDeathPenaltyParity.mjs",
    "assert:battle-numeric-coercion": "node scripts/assertBattleNumericCoercionParity.mjs",
